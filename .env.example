# ═══════════════════════════════════════════════════════════
#                   SentinelPeg — Environment
#              Configured for TESTNET deployment
# ═══════════════════════════════════════════════════════════

# ── Unichain Sepolia (Testnet) ──
UNICHAIN_RPC_URL=https://sepolia.unichain.org
UNICHAIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
UNICHAIN_CHAIN_ID=1301

# ── Reactive Network Lasna (Testnet) ──
# NOTE: Kopli is deprecated — Lasna is the active testnet
REACTIVE_RPC_URL=https://lasna-rpc.rnk.dev
REACTIVE_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
REACTIVE_CHAIN_ID=5318007

# ── Ethereum Sepolia (Origin Chain for monitoring) ──
ETHEREUM_RPC_URL=https://rpc.sepolia.org
ETHEREUM_CHAIN_ID=11155111

# ── Deployer ──
DEPLOYER_ADDRESS=0xYOUR_DEPLOYER_ADDRESS

# ── Contract Addresses (fill after deployment) ──
POOL_MANAGER_ADDRESS=0x00b036b58a818b1bc34d502d3fe730db729e62ac
HOOK_ADDRESS=
REACTIVE_CONTRACT_ADDRESS=
REACTIVE_CALLBACK_PROXY=0x9299472A6399Fd1027ebF067571Eb3e3D7837FC4

# ── Monitored Pool Config ──
# IMPORTANT: Testnets cannot mix with mainnets on Reactive Network.
# We monitor a Uniswap V2 pair on Ethereum Sepolia (not mainnet).
# The Reactive demos use Factory: 0x7E0987E5b3a30e3f2828572Bb659A548460a3003
# You can use an existing pair or deploy your own tokens + pair.
USDC_ETH_POOL=0x1DD11fD3690979f2602E42e7bBF68A19040E2e25
USDC_ADDRESS=0x2AFDE4A3Bca17E830c476c568014E595EA916a04
STABLECOIN_IS_TOKEN0=true
REFERENCE_ETH_PRICE=3000

# ── Sepolia Uniswap V2 Addresses (for creating your own pair) ──
SEPOLIA_V2_FACTORY=0x7E0987E5b3a30e3f2828572Bb659A548460a3003
SEPOLIA_V2_ROUTER=0xC532a74256D3Db42D0Bf7a0400fEFDbad7694008
SEPOLIA_WETH=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14

# ── Pool Registration (for ConfigureHook.s.sol) ──
# Fill after creating the pool on Unichain Sepolia
# currency0 must be numerically less than currency1
POOL_CURRENCY0=
POOL_CURRENCY1=
POOL_TICK_SPACING=60

# ── Block Explorers ──
# Unichain Sepolia:  https://unichain-sepolia.blockscout.com
# Reactive Lasna:    https://lasna.reactscan.net
# Ethereum Sepolia:  https://sepolia.etherscan.io

# ── Etherscan Verification ──
ETHERSCAN_API_KEY=
