# ── Unichain Deployment ──
UNICHAIN_RPC_URL=https://mainnet.unichain.org
UNICHAIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
UNICHAIN_CHAIN_ID=130

# ── Reactive Network Deployment ──
REACTIVE_RPC_URL=https://kopli-rpc.rkt.ink
REACTIVE_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
REACTIVE_CHAIN_ID=5318008

# ── Ethereum (Origin Chain for monitoring) ──
ETHEREUM_RPC_URL=https://eth.llamarpc.com
ETHEREUM_CHAIN_ID=1

# ── Contract Addresses (fill after deployment) ──
POOL_MANAGER_ADDRESS=
HOOK_ADDRESS=
REACTIVE_CONTRACT_ADDRESS=

# ── Monitored Pool Config ──
# Uniswap V2 USDC/ETH pool on Ethereum mainnet
USDC_ETH_POOL=0xB4e16d0168e52d35CaCD2c6185b44281Ec28C9Dc
USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
STABLECOIN_IS_TOKEN0=true
REFERENCE_ETH_PRICE=3000000000

# ── Etherscan Verification ──
ETHERSCAN_API_KEY=
